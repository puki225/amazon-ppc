# =====================
# Amazon Ads API PPC Proxy — Environment Variables
# =====================

# --- LWA (Login with Amazon) ---
# Same client ID and secret as your MCF proxy
LWA_CLIENT_ID=your_lwa_client_id
LWA_CLIENT_SECRET=your_lwa_client_secret

# Refresh token — may be the same as your SP-API token IF advertising::campaign_management
# scope was included when you authorized. If unsure, re-authorize with that scope added.
ADS_REFRESH_TOKEN=your_ads_refresh_token

# --- Ads API ---
# Your advertising profile ID — find it by hitting GET /ppc/profiles after boot
ADS_PROFILE_ID=your_profile_id

# EU endpoint (change to advertising-api.amazon.com for NA, advertising-api-fe.amazon.com for FE)
ADS_HOST=advertising-api-eu.amazon.com

# --- Profitability rules ---
# Hard ACoS ceiling — bids will NEVER be raised on keywords above this threshold
# 0.15 = 15% (half your 30% gross margin)
TARGET_ACOS=0.15

# --- Safety ---
# Set to true to log all changes without pushing to Amazon — run this first
DRY_RUN=true

# Optional: protect this proxy with an API key
PROXY_API_KEY=your_secret_key_here

# Port (use 3001 to avoid conflicting with your MCF proxy on 3000)
PORT=3001

# --- Postgres (for ASIN-linked PPC performance sync) ---
# Same instance as the MCF/SP-API proxy — copy DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
# from that service's Railway variables. Used by POST /ppc/sync-advertised-products and
# POST /setup-db. Leave unset if you only need the existing /ppc/reports/* routes.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
